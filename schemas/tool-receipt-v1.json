{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://timelayer-os.com/schemas/tl-gate/tool-receipt-v1.json",
  "title": "tl-gate.tool_receipt/1",
  "description": "Proves admission of one exact executor profile (SPEC §11.3). Any binary/image/schema/connector change requires a new tool receipt. Draft mirror (human-readable) of the wire form. Field set is normative per SPEC.ru.md §10–11; the binary wire encoding of receipts freezes before Phase 0 exit (intent encoding is already frozen in TL-GATE-WIRE-v1.md). Digest notation: b3:<64 lowercase hex> (BLAKE3-256). Consumers reject unknown fields — fail-closed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "wire",
    "receipt_kind",
    "receipt_id",
    "chain_id",
    "action_id",
    "attempt",
    "principal_id",
    "agent_instance_id",
    "orchestrator_id",
    "subject_digest",
    "policy_digest",
    "causal_parent_digest",
    "previous_receipt_digest",
    "local_poh_tick",
    "nonce",
    "issuer_ref",
    "receipt_digest",
    "tool_id",
    "tool_version",
    "binary_or_image_digest",
    "connector_id",
    "connector_version",
    "input_schema_digest",
    "output_schema_digest",
    "environment_profile_digest",
    "secret_handle_policy",
    "allowed_endpoints",
    "isolation_profile"
  ],
  "properties": {
    "wire": {
      "const": "TL-GATE-WIRE:v1"
    },
    "receipt_kind": {
      "enum": [
        "permission_receipt",
        "scope_receipt",
        "tool_receipt",
        "execution_receipt",
        "validation_receipt",
        "final_receipt"
      ],
      "const": "tool_receipt"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "chain_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "principal_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "orchestrator_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "policy_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "causal_parent_digest": {
      "type": "string",
      "pattern": "^$|^b3:[0-9a-f]{64}$"
    },
    "previous_receipt_digest": {
      "type": "string",
      "pattern": "^$|^b3:[0-9a-f]{64}$"
    },
    "local_poh_tick": {
      "type": "integer",
      "minimum": 0
    },
    "wall_clock_hint": {
      "type": "string",
      "description": "Informational only — never the sole authorization criterion (SPEC §10.1, P-11)."
    },
    "nonce": {
      "type": "string",
      "minLength": 1
    },
    "issuer_ref": {
      "type": "string",
      "minLength": 1
    },
    "receipt_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "tool_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "binary_or_image_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "connector_id": {
      "type": "string",
      "minLength": 1
    },
    "connector_version": {
      "type": "string",
      "minLength": 1
    },
    "input_schema_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "output_schema_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "environment_profile_digest": {
      "type": "string",
      "pattern": "^b3:[0-9a-f]{64}$"
    },
    "secret_handle_policy": {
      "type": "object"
    },
    "allowed_endpoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "isolation_profile": {
      "type": "string",
      "minLength": 1
    }
  }
}
